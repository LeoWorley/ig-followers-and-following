IG_USERNAME=your_username
IG_PASSWORD=your_password
TARGET_ACCOUNT=account_to_track

# Core runtime
HEADLESS_MODE=true
LOGIN_ONLY_MODE=false
LOGIN_ONLY_TIMEOUT_SECONDS=600
RUN_INTERVAL_MINUTES=60
RUN_JITTER_SECONDS=120
DB_INTEGRITY_CHECK_EVERY_RUNS=0
DB_VACUUM_EVERY_RUNS=0
SCRAPE_MODAL_WAIT_SECONDS=10
SCRAPE_STALL_TIMEOUT_SECONDS=15
SCRAPE_MAX_ITERATIONS=500
SCRAPE_MIN_COVERAGE_FOR_LOST=0.9
SCRAPE_MIN_REFERENCE_COUNT_FOR_LOST=100
STOP_ON_AUTH_FAILURE=true
DELETE_INVALID_COOKIE_ON_FAIL=true

# Logging
LOG_FILE=tracker.log
LOG_LEVEL=INFO
LOG_CONSOLE=true
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3
FORCE_KILL_CHROME=true
ALERTS_ENABLED=false
ALERT_CHANNELS=webhook,desktop
ALERT_COOLDOWN_SECONDS=1800
ALERT_STALE_SUCCESS_HOURS=0

# Tray app
TRAY_AUTO_START=false
TRAY_MONITOR_ONLY=false
TRAY_AUTO_MONITOR_ON_SCHEDULER=true
TRAY_LOG_PATH=tracker.log
TRAY_REPORTS_DIR=reports
TRAY_REPORT_DAYS=7
TRAY_STATUS_POLL_SECONDS=5

# GUI app
GUI_AUTO_START=false
GUI_MONITOR_ONLY=false
GUI_SETUP_COMPLETE=false
BACKGROUND_TRACKING_ENABLED=false
GUI_LOG_PATH=tracker.log
GUI_REPORTS_DIR=reports
GUI_REPORT_DAYS=7
GUI_STATUS_POLL_SECONDS=5
GUI_OPTIONS_POLL_SECONDS=30

# Web dashboard (mobile read-only)
WEB_ENABLED=false
WEB_HOST=127.0.0.1
WEB_PORT=8088
WEB_TZ=America/Hermosillo
WEB_AUTH_MODE=session
WEB_AUTH_USER=admin
WEB_AUTH_PASSWORD_HASH=pbkdf2_sha256$260000$replace_with_salt$replace_with_hash
WEB_SESSION_SECRET=replace_with_random_48_byte_secret
WEB_SESSION_COOKIE_SECURE=true
WEB_SESSION_TTL_SECONDS=43200
WEB_LOGIN_RATE_LIMIT_ATTEMPTS=5
WEB_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
